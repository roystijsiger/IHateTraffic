# Google Maps API Key
# Aanmaken op: https://console.cloud.google.com/
# 1. Maak Google Cloud account
# 2. Enable Distance Matrix API
# 3. Maak API key aan
# 4. BELANGRIJK: Stel quota in bij API Console (zie GOOGLE_MAPS_SETUP.md)
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Firebase Configuration
# Deze keys zijn bedoeld om publiek te zijn en worden beschermd door Firebase Security Rules
# Verkrijg deze van Firebase Console: https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
